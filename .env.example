# Plantilla de configuracion. Copiar a '.env' y poner los datos reales:
#
#     cp .env.example .env
#
# El archivo '.env' no debe subirse al repositorio: contiene la API Key.
# Reglas de sintaxis: sin espacios alrededor del '=', sin comillas,
# y la URL sin diagonal al final.

# URL del servidor Odoo 19, se proporcionará
ODOO_URL=http://localhost:8069

# Nombre de la base de datos a la que se conectan los ejemplos.
# A proporcionar externamente.
ODOO_BASE_DATOS=odoo19

# API Key del usuario, generada en Odoo desde:
# Ajustes > Usuarios > (usuario) > Seguridad de la cuenta > Claves API.
# La clave hereda los permisos del usuario que la genero.
# Se proporcionará clave ejemplo
ODOO_CLAVE_API=coloca_aqui_tu_api_key
